^https?:\/\/gss0\.bdstatic\.com\/.+?\/static\/wiseindex\/img\/bd_red_packet\.png reject-img
#^https:\/\/dss0\.bdstatic\.com\/.+/tam-ogel\/.+\.jpg _ reject

